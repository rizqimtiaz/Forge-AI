# ============================================================================
# Forge-AI — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# All AI routes gracefully degrade to deterministic mock pipelines when keys
# are absent, so the monorepo is fully runnable with zero configuration.
# ============================================================================

# Anthropic (Claude Opus 4.7) — used across all three labs for reasoning
ANTHROPIC_API_KEY=

# OpenAI (GPT-4 Vision + DALL-E 3) — used for OCR and generation fallbacks
OPENAI_API_KEY=

# Stability AI — Stable Diffusion Inpainting (Asset-AI)
STABILITY_API_KEY=

# Replicate — Segment-Anything-2 + ControlNet (Asset-AI + ChromaSketch)
REPLICATE_API_TOKEN=

# Optional: override the Anthropic model slug
ANTHROPIC_MODEL=claude-opus-4-7-20250514

# Optional: override the OpenAI model slug
OPENAI_VISION_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3
